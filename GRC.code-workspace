{
  "folders": [
    {
      "name": "GRC FRONT",
      "path": "."
    },
    {
      "name": "GRC BACKEND",
      "path": "../GRC-BACKEND"
    }
  ],
  "tasks": {
    "version": "2.0.0",
    "tasks": [
      {
        "label": "GRC: Frontend",
        "type": "shell",
        "command": "npm.cmd run dev",
