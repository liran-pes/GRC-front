          "cwd": "${workspaceFolder:GRC FRONT}"
        },
        "isBackground": true,
        "problemMatcher": []
      },
      {
        "label": "GRC: Backend",
        "type": "shell",
        "command": ".\\.venv\\Scripts\\python.exe -m uvicorn app.main:app --reload --host 127.0.0.1 --port 8000",
        "options": {
          "cwd": "${workspaceFolder:GRC BACKEND}"
        },
        "isBackground": true,
        "problemMatcher": []
      },
      {
        "label": "GRC: Full Stack",
        "dependsOn": ["GRC: Backend", "GRC: Frontend"],
        "dependsOrder": "parallel",
        "problemMatcher": []
      }
    ]
  }
